{
  "expo": {
    "name": "OneOnOne",
    "slug": "1on1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "oneonone",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9FC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oneonone.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F9FC"
      },
      "package": "com.oneonone.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow OneOnOne to use Face ID for authentication."
        }
      ],
      "./plugins/withGradle813"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "737d36e1-dc2c-4d6d-89a6-af1a7d0b4957"
      }
    },
    "owner": "new_session"
  }
}
