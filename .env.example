# PostgreSQL — локально или Supabase (Connection String из Settings > Database)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_1on1

# Redis — локально или Railway Redis addon
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Сгенерируй: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-random-string

# Для продакшена: URL фронтенда на Railway (через запятую)
# CORS_ORIGINS=https://your-frontend.up.railway.app
