# OneOnOne backend configuration — set these in the host's env (Railway, VPS,
# Yandex Cloud, Timeweb, etc). Switching DB or host = changing these values only.
# NEVER commit real secrets.

# --- Database (any standard PostgreSQL: Supabase / Timeweb / Yandex Managed PG) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Auth (Supabase JWT verification) ---
SUPABASE_JWT_SECRET=
# Flip auth enforcement ON only after the secret above is set (else access breaks)
AUTH_ENFORCE=0

# --- Entitlements / plans enforcement ---
ENTITLEMENTS_ENFORCE=0

# --- Billing / payments (CloudPayments; provider is pluggable) ---
PAYMENT_PROVIDER=cloudpayments
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
CLOUDPAYMENTS_WEBHOOK_HMAC=
BILLING_GRACE_DAYS=3

# --- Web cabinet (deep-link returns, redirects) ---
WEB_BASE_URL=https://your-web-app.example
APP_DEEPLINK_SCHEME=oneonone

# --- Investor metrics inputs (CAC / LTV / ROI) ---
MARKETING_SPEND_KOPECKS=0
NEW_PAID_CUSTOMERS=0
MONTHLY_CHURN=0.05
ROI_HOURLY_RATE_KOPECKS=0
ROI_SAVED_HOURS_PER_MEETING=0.5

# --- AI provider (already supported) ---
AITUNNEL_KEY=

# --- Misc ---
# Enable destructive dev endpoints (reset-db) only in local/dev:
ENABLE_DEV_ENDPOINTS=0
