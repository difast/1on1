# ─── Supabase (фронтенд читает напрямую, минуя бэкенд) ───────────
# Supabase dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Бэкенд API ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api

# NOTE: фронтенд читает из Supabase таблицы:
#   leads            — лиды с лендинга (INSERT через anon key)
#   meeting_templates — шаблоны повесток (SELECT через anon key)
# Всё остальное — через VITE_API_URL (Railway бэкенд).
