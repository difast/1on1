# ─── Railway PostgreSQL (основная база) ───────────────────────────
# Берётся из Railway dashboard → Postgres → Connect → DATABASE_URL
DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

# ─── Redis (Railway Redis addon) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Безопасность ─────────────────────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-random-string

# ─── CORS ─────────────────────────────────────────────────────────
# URL фронтенда через запятую (без слеша в конце)
CORS_ORIGINS=http://localhost:5173

# NOTE: бэкенд обращается ТОЛЬКО к Railway PostgreSQL.
# Supabase читает фронтенд напрямую (anon key, RLS).
